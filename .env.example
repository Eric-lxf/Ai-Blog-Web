# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3306

# Redis
REDIS_PORT=6379

# 服务端口
BACKEND_PORT=8080
FRONTEND_PORT=80

# 前端 Nginx 反代后端地址（docker compose 默认同网络服务名 backend；前后端分开部署时改为宿主机 IP 或 172.17.0.1）
BACKEND_HOST=backend

# 前端 Docker：2C4G 默认在宿主机 build dist，docker 只打 nginx 包（避免容器内 vite OOM）
FRONTEND_DOCKERFILE=frontend/Dockerfile
FRONTEND_LOW_MEM_BUILD=1
FRONTEND_NODE_HEAP_MB=1024
# 构建时限流 CPU，避免 2C 机器卡死（nice 0-19，越大越省 CPU）
FRONTEND_BUILD_NICE=10
# 前端构建前暂停已运行容器，减轻 CPU/内存争抢
PAUSE_DOCKER_DURING_FRONTEND_BUILD=1
# 8G+ 机器若要在 docker 内完整 vite 构建：FRONTEND_DOCKERFILE=frontend/Dockerfile.full

# AI（博客智写/优化必填）
DEEPSEEK_API_KEY=
