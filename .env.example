# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3306

# Redis
REDIS_PORT=6379

# 服务端口
BACKEND_PORT=8080
FRONTEND_PORT=80

# 前端 Nginx 反代后端地址（docker compose 默认同网络服务名 backend；前后端分开部署时改为宿主机 IP 或 172.17.0.1）
BACKEND_HOST=backend

# 前端 Docker 构建（2C4G 机器默认 1024；仍 OOM 可改为 768 并确保宿主机有 swap）
FRONTEND_LOW_MEM_BUILD=1
FRONTEND_NODE_HEAP_MB=1024

# AI（博客智写/优化必填）
DEEPSEEK_API_KEY=
