# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3306

# Redis
REDIS_PORT=6379

# 服务端口
BACKEND_PORT=8080
FRONTEND_PORT=80

# 前端 Nginx 反代后端地址（docker compose 默认同网络服务名 backend；前后端分开部署时改为宿主机 IP 或 172.17.0.1）
BACKEND_HOST=backend

# AI（推荐在管理后台「AI博客 → AI模型配置」中配置多厂商 Key）

# 对象存储（可选；对应 application.yml 中 novamall.oss）
# NOVAMALL_OSS_ENABLED=false
# NOVAMALL_OSS_KEY_ID=
# NOVAMALL_OSS_KEY_SECRET=
# NOVAMALL_OSS_BUCKET=
# NOVAMALL_OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
# NOVAMALL_OSS_DOMAIN=